# Copy these into Railway → Service → Variables

NODE_ENV=production
JWT_SECRET=generate_a_long_random_string_min_32_chars
JWT_EXPIRE=7d

# MongoDB Atlas (SRV works on Railway/Linux)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/luxora?retryWrites=true&w=majority

# Your live frontend URL (no trailing slash)
CLIENT_URL=https://your-frontend.vercel.app

# Optional — payments & email
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_xxx
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Luxora Store <noreply@yourstore.com>

# Railway sets PORT automatically — do not set manually
